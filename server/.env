# PostgreSQL 配置（生产环境使用）
# 取消注释以下配置以使用 PostgreSQL
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=

# JWT 密钥
JWT_SECRET=call-center-secret-key-2024

# 后端服务端口
PORT=3001

# Twilio 配置（可选）
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_CALLBACK_URL=

# 邮件配置（可选）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
