# ============================================
# 自动拨号客服系统 - 环境变量配置示例
# 复制此文件为 .env 并修改配置
# ============================================

# 数据库类型: sqlite | postgres | memory
DB_TYPE=sqlite

# SQLite 配置（开发环境默认）
SQLITE_PATH=./data/database.sqlite

# PostgreSQL 配置（生产环境使用）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=callcenter
# DB_USER=postgres
# DB_PASSWORD=postgres

# 后端服务端口
PORT=8081

# JWT 密钥（用于身份验证）
JWT_SECRET=call-center-secret-key-2024

# ============================================
# Twilio 配置（可选，用于电话功能）
# ============================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_CALLBACK_URL=

# ============================================
# 邮件配置（可选，用于通知功能）
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
