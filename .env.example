# 客服外呼系统环境变量配置
# 复制此文件为 .env 并根据需要修改

# ===================
# 端口配置
# ===================
# 前端端口（宿主机访问端口）
HTTP_PORT=8080

# 后端 API 端口（宿主机访问端口）
API_PORT=8081

# ===================
# 子路径部署配置
# ===================
# 如果需要通过子路径访问（如 http://yourdomain.com/callcenter/）
# 请设置 VITE_BASE_PATH 为子路径名称（不带末尾斜杠）
# 
# 示例：
#   直接访问端口：VITE_BASE_PATH=/（或不设置）
#   子路径部署：VITE_BASE_PATH=/callcenter
#
# 注意：修改此变量后需要重新构建前端镜像
VITE_BASE_PATH=/

# ===================
# 其他配置（可选）
# ===================
# JWT 密钥（建议修改为随机字符串）
# JWT_SECRET=your-random-secret-key-here
